# Database (Digital Ocean PostgreSQL)
DB_HOST=your-do-managed-db-host.ondigitalocean.com
DB_PORT=25060
DB_USERNAME=doadmin
DB_PASSWORD=your-password
DB_NAME=kaaval_ai

# Redis
REDIS_HOST=your-redis-host.ondigitalocean.com
REDIS_PORT=25061

# AWS S3 Configuration (for image storage)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_NAME=your-s3-bucket-name
S3_BUCKET_URL=https://your-s3-bucket-name.s3.ap-south-1.amazonaws.com

# JWT
JWT_SECRET=your-strong-random-secret-at-least-32-chars
JWT_EXPIRY=8h

# Server
PORT=8003
NODE_ENV=production

# CORS (comma-separated frontend origins)
CORS_ORIGINS=https://yourdomain.com

# AI Worker (Python CV pipeline)
AI_BACKEND_URL=http://127.0.0.1:8000
# Secret key sent in x-api-key header when calling the Python AI worker
AI_API_KEY=your-ai-worker-secret-key

# RDK Edge Camera API key (sent by edge devices to /api/violations/detect)
RDK_API_KEY=your-rdk-edge-camera-secret-key
