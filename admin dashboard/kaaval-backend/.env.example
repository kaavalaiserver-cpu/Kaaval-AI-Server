# ============================================================
# KAAVAL AI – Backend Environment Configuration
# Copy this file to .env and fill in all values before deploying
# ============================================================

# ── Database ─────────────────────────────────────────────────
# DB_TYPE: "postgres" | "sqlite" | "auto" (default: auto-detect)
DB_TYPE=postgres

# AWS RDS / EC2 PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-strong-password
DB_NAME=kaaval_ai

# ── Redis (optional, falls back to in-memory if unavailable) ─
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-secret
JWT_EXPIRY=8h

# ── Server ───────────────────────────────────────────────────
PORT=8003
NODE_ENV=production

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# ── AWS S3 (image storage) ───────────────────────────────────
# Leave blank to disable S3 (images stored locally)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=kaaval-ai-images

# ── AI Backend (Python FastAPI / OCR pipeline) ───────────────
AI_BACKEND_URL=http://127.0.0.1:8000

# ── API Keys ─────────────────────────────────────────────────
# Secret key sent in x-api-key header by the Python AI worker
AI_API_KEY=your-ai-worker-secret

# Secret key sent by RDK edge cameras in x-api-key header
RDK_API_KEY=your-rdk-edge-camera-key

# Plate Recognizer API key (used by Python analytics service)
PLATE_RECOGNIZER_API_KEY=your-plate-recognizer-api-key
