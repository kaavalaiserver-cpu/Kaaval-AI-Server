# ── PostgreSQL Database ──────────────────────────────────────────────────────────
# Replace with your actual PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/kaaval

# ── AWS S3 ───────────────────────────────────────────────────────────────────
# If running on EC2 with an IAM role, AWS_ACCESS_KEY_ID is NOT needed.
# Just specify the region and bucket name.
AWS_REGION=ap-south-1
S3_IMAGES_BUCKET=kaaval-ai-images
PRESIGN_TTL=300

# ── API Security ─────────────────────────────────────────────────────────────
# Edge cameras must send this in the x-api-key header for /ingest
RDK_API_KEY=change-me-rdk-secret

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
