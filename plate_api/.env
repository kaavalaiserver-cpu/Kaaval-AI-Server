# Public URL used in image links sent to dashboard
PUBLIC_BASE_URL=${PUBLIC_BASE_URL:-https://images.kaaval-ai.com}

# Public path serving images from plate_api
PUBLIC_IMAGE_PATH=${PUBLIC_IMAGE_PATH:-/images}

# Backend service URLs (will be set by environment)
