# Public URL used in image links sent to dashboard
# For AWS: Set to your S3 bucket or CloudFront CDN URL
PUBLIC_BASE_URL=https://images.kaaval-ai.com

# Public path serving images from plate_api
PUBLIC_IMAGE_PATH=/images

# Local backend endpoints
# For AWS: Set to your backend service URL (ECS, Lambda, etc.)
BACKEND_LOG_URL=http://localhost:8003/api/system/logs
BACKEND_API_URL=http://localhost:8003/api/violations/pipeline

# Plate recognition API settings
PLATE_API_TIMEOUT=5000
PLATE_MIN_CONFIDENCE=0.7
